<policies>
	<inbound>
		<base />
		<set-header name="X-Environment" exists-action="override">
			<value>{{environment}}</value>
		</set-header>
	</inbound>
	<backend>
		<base />
	</backend>
	<outbound>
		<base />
		<set-header name="X-Greeting-Source" exists-action="override">
			<value>apiops-scenario-b</value>
		</set-header>
	</outbound>
	<on-error>
		<base />
	</on-error>
</policies>