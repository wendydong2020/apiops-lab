<policies>
	<inbound>
		<base />
		<set-header name="X-Environment" exists-action="override">
			<value>{{environment}}</value>
		</set-header>
		<rate-limit calls="100" renewal-period="60" />
	</inbound>
	<backend>
		<base />
	</backend>
	<outbound>
		<base />
	</outbound>
	<on-error>
		<base />
	</on-error>
</policies>